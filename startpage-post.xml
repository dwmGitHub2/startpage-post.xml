<?xml version="1.0" encoding="UTF-8"?>
<OpenSearchDescription xmlns="http://a9.com/-/spec/opensearch/1.1/"
  xmlns:moz="http://www.mozilla.org/2006/browser/search/">

  <ShortName>Startpage POST</ShortName>
  <Description>Startpage search using POST</Description>
  <InputEncoding>UTF-8</InputEncoding>

  <!-- Web search via POST -->
  <Url type="text/html" method="POST" template="https://www.startpage.com/sp/search">
    <Param name="query" value="{searchTerms}"/>
  </Url>

  <!-- Suggestions -->
  <Url type="application/x-suggestions+json"
       template="https://www.startpage.com/osuggestions?q={searchTerms}"/>
</OpenSearchDescription>